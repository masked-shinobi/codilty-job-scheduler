{
  "name": "job-scheduler",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build:dashboard",
    "dev:api": "npm run dev -w apps/api",
    "dev:worker": "npm run dev -w apps/worker",
    "dev:dashboard": "npm run dev -w apps/dashboard",
    "build:api": "npm run build -w apps/api",
    "build:worker": "npm run build -w apps/worker",
    "build:dashboard": "npm run build -w apps/dashboard",
    "build:shared": "npm run build -w packages/shared",
    "db:migrate": "npx prisma migrate dev",
    "db:generate": "npx prisma generate",
    "db:studio": "npx prisma studio",
    "test": "npm run test --workspaces --if-present",
    "test:unit": "jest --testPathPattern=unit",
    "test:integration": "jest --testPathPattern=integration",
    "test:concurrency": "jest --testPathPattern=concurrency"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^22.0.0",
    "@types/supertest": "^6.0.0",
    "jest": "^29.7.0",
    "prisma": "^5.18.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.4.11",
    "typescript": "^5.5.0"
  },
  "dependencies": {
    "@prisma/client": "^5.18.0",
    "@types/uuid": "^10.0.0",
    "uuid": "^10.0.0"
  }
}
