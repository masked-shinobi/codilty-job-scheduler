generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ──────────────────────────────────────────────────────────────────────

enum OrgRole {
  OWNER
  ADMIN
  MEMBER
}

enum RetryStrategy {
  FIXED
  LINEAR
  EXPONENTIAL
}

enum JobStatus {
  QUEUED
  SCHEDULED
  CLAIMED
  RUNNING
  COMPLETED
  FAILED
  DEAD
}

enum ExecutionStatus {
  RUNNING
  COMPLETED
  FAILED
}

enum WorkerStatus {
  IDLE
  BUSY
  DEAD
}

enum LogLevel {
  INFO
  WARN
  ERROR
}

// ─── User ───────────────────────────────────────────────────────────────────────

model User {
  id        String   @id @default(uuid()) @db.Uuid
  clerkId   String   @unique
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())

  ownedOrgs   Organization[] @relation("OrgOwner")
  memberships OrgMember[]
}

// ─── Organization ───────────────────────────────────────────────────────────────

model Organization {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  ownerId   String   @db.Uuid
  createdAt DateTime @default(now())

  owner    User        @relation("OrgOwner", fields: [ownerId], references: [id])
  members  OrgMember[]
  projects Project[]
}

// ─── OrgMember (join table for RBAC) ────────────────────────────────────────────

model OrgMember {
  id     String  @id @default(uuid()) @db.Uuid
  orgId  String  @db.Uuid
  userId String  @db.Uuid
  role   OrgRole @default(MEMBER)

  org  Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([orgId, userId])
}

// ─── Project ────────────────────────────────────────────────────────────────────

model Project {
  id        String   @id @default(uuid()) @db.Uuid
  orgId     String   @db.Uuid
  name      String
  createdAt DateTime @default(now())

  org           Organization   @relation(fields: [orgId], references: [id], onDelete: Cascade)
  queues        Queue[]
  scheduledJobs ScheduledJob[]
}

// ─── Queue ──────────────────────────────────────────────────────────────────────

model Queue {
  id               String  @id @default(uuid()) @db.Uuid
  projectId        String  @db.Uuid
  name             String
  priority         Int     @default(0)
  concurrencyLimit Int     @default(5)
  isPaused         Boolean @default(false)
  createdAt        DateTime @default(now())

  project       Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  retryPolicy   RetryPolicy?
  jobs          Job[]
  scheduledJobs ScheduledJob[]
  deadLetterJobs DeadLetterJob[]

  @@unique([projectId, name])
}

// ─── RetryPolicy ────────────────────────────────────────────────────────────────

model RetryPolicy {
  id          String        @id @default(uuid()) @db.Uuid
  queueId     String        @unique @db.Uuid
  strategy    RetryStrategy @default(EXPONENTIAL)
  baseDelayMs Int           @default(1000)
  maxRetries  Int           @default(3)
  maxDelayMs  Int?

  queue Queue @relation(fields: [queueId], references: [id], onDelete: Cascade)
}

// ─── Job ────────────────────────────────────────────────────────────────────────

model Job {
  id           String    @id @default(uuid()) @db.Uuid
  queueId      String    @db.Uuid
  type         String
  payload      Json      @default("{}")
  status       JobStatus @default(QUEUED)
  priority     Int       @default(0)
  runAt        DateTime  @default(now())
  cronExpr     String?
  batchId      String?   @db.Uuid
  attemptCount Int       @default(0)
  maxAttempts  Int       @default(3)
  claimedBy    String?   @db.Uuid
  claimedAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  queue      Queue          @relation(fields: [queueId], references: [id], onDelete: Cascade)
  worker     Worker?        @relation(fields: [claimedBy], references: [id], onDelete: SetNull)
  executions JobExecution[]
  logs       JobLog[]
  deadLetter DeadLetterJob?
  heartbeats WorkerHeartbeat[]

  // Critical composite index for the claim query
  @@index([queueId, status, runAt])
}

// ─── JobExecution (one row per attempt) ─────────────────────────────────────────

model JobExecution {
  id            String          @id @default(uuid()) @db.Uuid
  jobId         String          @db.Uuid
  workerId      String?         @db.Uuid
  attemptNumber Int
  startedAt     DateTime        @default(now())
  finishedAt    DateTime?
  status        ExecutionStatus @default(RUNNING)
  result        Json?
  errorMessage  String?

  job    Job     @relation(fields: [jobId], references: [id], onDelete: Cascade)
  worker Worker? @relation(fields: [workerId], references: [id], onDelete: SetNull)
  logs   JobLog[]
}

// ─── Worker ─────────────────────────────────────────────────────────────────────

model Worker {
  id         String       @id @default(uuid()) @db.Uuid
  hostname   String
  pid        Int
  status     WorkerStatus @default(IDLE)
  startedAt  DateTime     @default(now())
  lastSeenAt DateTime     @default(now())

  claimedJobs Job[]
  executions  JobExecution[]
  heartbeats  WorkerHeartbeat[]
}

// ─── WorkerHeartbeat ────────────────────────────────────────────────────────────

model WorkerHeartbeat {
  id           String   @id @default(uuid()) @db.Uuid
  workerId     String   @db.Uuid
  timestamp    DateTime @default(now())
  currentJobId String?  @db.Uuid

  worker Worker @relation(fields: [workerId], references: [id], onDelete: Cascade)
  job    Job?   @relation(fields: [currentJobId], references: [id], onDelete: SetNull)

  @@index([workerId, timestamp(sort: Desc)])
}

// ─── JobLog (append-only) ───────────────────────────────────────────────────────

model JobLog {
  id          String   @id @default(uuid()) @db.Uuid
  jobId       String   @db.Uuid
  executionId String?  @db.Uuid
  timestamp   DateTime @default(now())
  level       LogLevel @default(INFO)
  message     String

  job       Job           @relation(fields: [jobId], references: [id], onDelete: Cascade)
  execution JobExecution? @relation(fields: [executionId], references: [id], onDelete: Cascade)
}

// ─── ScheduledJob (cron definitions — spawns real Job rows) ─────────────────────

model ScheduledJob {
  id          String   @id @default(uuid()) @db.Uuid
  projectId   String   @db.Uuid
  queueId     String   @db.Uuid
  cronExpr    String
  jobTemplate Json
  nextRunAt   DateTime
  isActive    Boolean  @default(true)

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  queue   Queue   @relation(fields: [queueId], references: [id], onDelete: Cascade)
}

// ─── DeadLetterJob ──────────────────────────────────────────────────────────────

model DeadLetterJob {
  id            String   @id @default(uuid()) @db.Uuid
  originalJobId String   @unique @db.Uuid
  queueId       String   @db.Uuid
  payload       Json
  failureReason String
  movedAt       DateTime @default(now())

  originalJob Job   @relation(fields: [originalJobId], references: [id])
  queue       Queue @relation(fields: [queueId], references: [id], onDelete: Cascade)
}
