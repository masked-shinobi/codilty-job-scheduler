# --- Database (Supabase free tier for production, or local docker-compose Postgres for dev) ---
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/jobscheduler?schema=public"

# --- Clerk Auth (https://dashboard.clerk.com) ---
CLERK_PUBLISHABLE_KEY="<CLERK_PUBLISHABLE_KEY>"
CLERK_SECRET_KEY="<CLERK_SECRET_KEY>"

# --- API server ---
PORT="4000"
NODE_ENV="development"
API_BASE_URL="http://localhost:4000"

# --- Frontend (Vite exposes only VITE_ prefixed vars) ---
VITE_CLERK_PUBLISHABLE_KEY="<CLERK_PUBLISHABLE_KEY>"
VITE_API_BASE_URL="http://localhost:4000"

# --- Worker service ---
WORKER_POLL_INTERVAL_MS="1000"
WORKER_HEARTBEAT_INTERVAL_MS="5000"
WORKER_CONCURRENCY_PER_INSTANCE="5"
STALE_WORKER_THRESHOLD_MS="30000"

# --- Internal service-to-service auth (worker -> API heartbeat endpoint) ---
INTERNAL_API_TOKEN="<GENERATE_RANDOM_SECRET_STRING>"

# --- Deployment (fill in once deployed) ---
RENDER_API_URL="<RENDER_OR_RAILWAY_API_URL>"
RENDER_WORKER_SERVICE_ID="<RENDER_OR_RAILWAY_WORKER_SERVICE_ID>"
VERCEL_PROJECT_URL="<VERCEL_DEPLOYED_FRONTEND_URL>"

# --- Optional bonus: AI failure summaries ---
GROQ_API_KEY=""
GEMINI_API_KEY=""
